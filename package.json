{
  "name": "video-components",
  "version": "1.0.0",
  "description": "Production Remotion components implementing video engagement techniques",
  "scripts": {
    "start": "remotion studio",
    "dev": "remotion studio",
    "build": "remotion render MarkKndActual out/markknd-actual.mp4",
    "build:range": "remotion render UIShowcaseRange out/ui-showcase-range.mp4",
    "build:polished": "remotion render UIShowcasePolished out/ui-showcase-polished.mp4",
    "build:iso": "remotion render IsometricShowcase out/isometric-showcase.mp4",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kitolochi/video-components.git"
  },
  "license": "MIT",
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.409",
    "@remotion/media-utils": "^4.0.409",
    "@remotion/zod-types": "^4.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "^4.0.0",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "^4.0.0",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.6.0",
    "typescript": "5.9.3"
  },
  "private": true
}
